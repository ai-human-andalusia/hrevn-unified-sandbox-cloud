# Streamlit Cloud secrets template (copy values into app Secrets UI).
# Do not commit real values.

AI_PRIMARY_PROVIDER = "openai"

# OpenAI (production / demo / communications)
OPENAI_ENABLED = "1"
OPENAI_API_KEY = ""
OPENAI_API_KEY_PRODUCTION = ""
OPENAI_API_KEY_DEMO = ""
OPENAI_API_KEY_COMMS = ""
OPENAI_MODEL = "gpt-4o-mini"
OPENAI_API_BASE_URL = "https://api.openai.com/v1"

# Gemini (latent/optional)
GEMINI_ENABLED = "0"
GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-1.5-flash"

# Gmail OAuth
GMAIL_ENABLED = "1"
GMAIL_CLIENT_ID = ""
GMAIL_CLIENT_SECRET = ""
GMAIL_REFRESH_TOKEN = ""
GMAIL_MAILBOX_USER = "me"

# SMTP fallback
SMTP_ENABLED = "1"
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = ""
SMTP_PASS = ""

# GitHub
GITHUB_ENABLED = "1"
GITHUB_REPO = ""
GITHUB_REMOTE_URL = ""
GITHUB_BRANCH = "main"
GITHUB_TOKEN = ""

# Telegram
TELEGRAM_ENABLED = "0"
TELEGRAM_BOT_TOKEN = ""
TELEGRAM_CHAT_ID = ""

# H-REVN signing (optional)
HREVN_SIGNING_ENABLED = "0"
HREVN_SIGNING_ISSUER = "H-REVN"
HREVN_SIGNING_KEY_ID = "hrevn-primary-signing-key-001"
HREVN_SIGNING_PRIVATE_KEY = ""
HREVN_SIGNING_VERIFICATION_URL = "https://hrevn.com/.well-known/hrevn-signing-key.json"
HREVN_SIGNING_PROFILE = "hrevn_signing_v1"

# Admin security alerts
SANDBOX_SECURITY_ALERT_EMAIL = ""
